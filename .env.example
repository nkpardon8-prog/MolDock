# Optional: NCBI API key for faster PubMed queries (free at ncbi.nlm.nih.gov/account)
# Without a key: 3 requests/sec. With a key: 10 requests/sec.
# NCBI_API_KEY=your_key_here

# Perplexity API key for AI-powered research search (required for AI Research tab)
# Get your key at https://www.perplexity.ai/settings/api
# PERPLEXITY_API_KEY=your_key_here

# NVIDIA BioNeMo API key for MolMIM molecular generation (free at build.nvidia.com)
# NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxx
